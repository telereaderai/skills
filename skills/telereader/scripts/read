#!/usr/bin/env node
// Telereader skill — submit text/a URL/a file and print the openable reader URL.
// Ported from bash to node for a stable, fast runtime (node is guaranteed: `npx
// skills` requires it). The old bash empty-body check span-locked macOS bash 3.2
// on large inputs; this is O(n) and instant.
//
// Usage:
//   read "Some text to read aloud."          # literal text
//   read https://example.com/article         # a URL — Telereader fetches+cleans it
//   read article.md --title "My article"     # a readable local file
//   pbpaste | read -                         # stdin
// Flags: --title <t>  --voice <v>  --open (off by default; we never auto-open)
//
// The token comes from $TELEREADER_TOKEN or ~/.config/telereader/token — NEVER
// from argv, so it can't leak into `ps`.
'use strict';

const { spawn } = require('node:child_process');
const lib = require('./lib.js');

function readStdin() {
  return new Promise((resolve) => {
    if (process.stdin.isTTY) { resolve(''); return; }
    let buf = '';
    process.stdin.setEncoding('utf8');
    process.stdin.on('data', (c) => { buf += c; });
    process.stdin.on('end', () => resolve(buf));
    process.stdin.on('error', () => resolve(buf));
  });
}

function parseArgs(argv) {
  const out = { title: '', voice: '', open: false, positional: [] };
  let i = 0;
  let passthrough = false;
  while (i < argv.length) {
    const a = argv[i];
    if (passthrough) { out.positional.push(a); i += 1; continue; }
    switch (a) {
      case '--title': out.title = argv[i + 1] || ''; i += 2; break;
      case '--voice': out.voice = argv[i + 1] || ''; i += 2; break;
      case '--open': out.open = true; i += 1; break;
      case '--': passthrough = true; i += 1; break;
      default: out.positional.push(a); i += 1; break;
    }
  }
  return out;
}

function openInBrowser(url) {
  const cmd = process.platform === 'darwin' ? 'open'
    : process.platform === 'win32' ? 'cmd'
      : 'xdg-open';
  const args = process.platform === 'win32' ? ['/c', 'start', '', url] : [url];
  try {
    const child = spawn(cmd, args, { stdio: 'ignore', detached: true });
    child.on('error', () => {});
    child.unref();
  } catch { /* best effort */ }
}

async function main() {
  const args = parseArgs(process.argv.slice(2));
  const firstPositional = args.positional[0];
  const needStdin = firstPositional == null || firstPositional === '-';
  const stdinBody = needStdin ? await readStdin() : '';

  const source = lib.resolveSource(firstPositional, stdinBody);

  // Blank-check only the inline-body sources (url sources have no body).
  if (source.kind !== 'url' && lib.isBlank(source.body)) {
    process.stderr.write('no text to read (pass a string, a URL, a file, or pipe text on stdin)\n');
    process.exit(1);
  }

  if (!lib.readToken()) {
    process.stderr.write('Not onboarded. Run the onboard script next to this one (scripts/onboard).\n');
    process.exit(1);
  }

  try {
    const { readUrl, mode, ids } = await lib.submitReading({
      source, title: args.title, voice: args.voice,
    });
    // Print the readUrl. We DO NOT auto-open — the agent offers to open it.
    process.stdout.write(readUrl + '\n');
    const idStr = lib.formatTraceIds(ids);
    if (idStr) process.stderr.write(`(${mode || 'ok'}; ${idStr})\n`);
    if (args.open) openInBrowser(readUrl);
    process.exit(0);
  } catch (err) {
    const ids = err.ids || {};
    const idStr = lib.formatTraceIds(ids);
    const idSuffix = idStr ? ` [${idStr}]` : '';

    if (err.status === 402) {
      process.stderr.write(
        'Telereader returned 402 Payment Required — URL/document import is a paid ' +
        'feature on this account.\n' +
        'Fallback: fetch the page/document text yourself and pass it as text, e.g.\n' +
        '  read "<the extracted text>"   (or pipe it on stdin: ... | read -)\n' +
        `${err.message ? 'detail: ' + err.message + '\n' : ''}${idSuffix ? 'trace:' + idSuffix + '\n' : ''}`,
      );
      process.exit(2);
    }

    if (err.code === 'not_onboarded') {
      process.stderr.write('Not onboarded. Run the onboard script (scripts/onboard).\n');
      process.exit(1);
    }

    process.stderr.write(
      `error: ${err.code}${err.status ? ' (HTTP ' + err.status + ')' : ''}${idSuffix}\n` +
      `${err.message ? err.message + '\n' : ''}` +
      (err.status >= 500 ? 'This looks like a server error — report the trace id above and offer to file a bug.\n' : ''),
    );
    process.exit(1);
  }
}

main().catch((err) => {
  process.stderr.write(`unexpected error: ${err && err.stack ? err.stack : err}\n`);
  process.exit(1);
});
